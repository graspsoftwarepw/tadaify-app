{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "tadaify",
  "compatibility_date": "2026-04-04",
  "compatibility_flags": ["nodejs_compat"],
  "main": "./workers/app.ts",
  "vars": {},

  // R2 bucket binding for avatar uploads (TR-tadaify-003)
  // @cloudflare/vite-plugin reads THIS file (via configPath in vite.config.ts)
  // so miniflare emulates the R2 binding locally.
  //
  // This file is NOT used by `wrangler deploy` (which reads wrangler.jsonc).
  // When the tadaify-aws infra PR provisions the real bucket, move r2_buckets
  // back to wrangler.jsonc and remove this file + the configPath override.
  "r2_buckets": [
    { "binding": "AVATARS_R2", "bucket_name": "tadaify-avatars" }
  ],

  // Cron trigger: avatar orphan cleanup + GDPR pending_r2_deletes consumer
  // Daily at 03:00 UTC (TR-tadaify-003, ECN-138-06, ECN-138-12)
  "triggers": {
    "crons": ["0 3 * * *"]
  }

  // Workers AI binding (uncomment in F-AI-SUGGEST story)
  // [ai]
  // binding = "AI"
}
