{
  "name": "tadaify-app",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "cf-typegen": "wrangler types",
    "deploy": "react-router build && wrangler deploy",
    "dev": "react-router dev --port 5173 --strictPort",
    "postinstall": "wrangler types",
    "preview": "react-router build && vite preview --port 4321 --strictPort",
    "setup": "bash bin/e2e-bootstrap.sh",
    "typecheck": "wrangler types && react-router typegen && tsc -b",
    "test": "vitest run",
    "test:local:prepare": "bash bin/e2e-local-env.sh --reset",
    "test:e2e": "playwright test",
    "test:e2e:local": "npm run test:local:prepare && bash -c 'set -a; source .env.local; set +a; E2E_ENV=local playwright test \"$@\"' --",
    "test:e2e:ui:local": "npm run test:local:prepare && bash -c 'set -a; source .env.local; set +a; E2E_ENV=local playwright test --ui \"$@\"' --",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "PWDEBUG=1 playwright test"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "isbot": "^5.1.36",
    "lucide-react": "^1.14.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "7.14.0",
    "simple-icons": "^16.18.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.29.1",
    "@playwright/test": "^1.59.1",
    "@react-router/dev": "7.14.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vitest": "^4.1.5",
    "wrangler": "^4.75.0"
  }
}
